NODE_ENV=production
HOST=0.0.0.0
PORT=8080
BODYCOMPASS_DATA_DIR=/data

# Server-only secret used for protected persistence internals. Users never enter this.
# Generate with: openssl rand -hex 32
BODYCOMPASS_STORAGE_SECRET=replace-with-at-least-32-random-characters
BODYCOMPASS_AUTH_SECRET=replace-with-a-different-32-byte-random-secret

# Passwordless email sign-in through Resend. The From address must use a
# domain verified in Resend before friend testing.
RESEND_API_KEY=
BODYCOMPASS_EMAIL_FROM=BodyCompass <login@your-verified-domain.example>

# Keep provider keys only in the server environment or your host's secret manager.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
