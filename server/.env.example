PORT=8080
HOST=127.0.0.1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Email OTP delivery. Without a Resend key, local development returns the code
# in the API response; production requires both values.
RESEND_API_KEY=
BODYCOMPASS_EMAIL_FROM=BodyCompass <login@your-verified-domain.example>

# Server-only secret. User sessions are created by register/sign-in and stored hashed.
BODYCOMPASS_STORAGE_SECRET=
BODYCOMPASS_AUTH_SECRET=
BODYCOMPASS_DATA_DIR=server-data

# Optional per-user daily AI limits (reset at 00:00 UTC).
BODYCOMPASS_DAILY_MEAL_AI_LIMIT=10
BODYCOMPASS_DAILY_CHAT_AI_LIMIT=30
BODYCOMPASS_DAILY_PROGRESS_AI_LIMIT=3
